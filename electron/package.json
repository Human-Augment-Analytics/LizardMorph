{
  "name": "lizardmorph",
  "version": "1.0.6",
  "description": "LizardMorph - Automated lizard morphology analysis",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.lizardmorph.desktop",
    "productName": "LizardMorph",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Human-Augment-Analytics",
        "repo": "LizardMorph"
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icons/icon.png",
      "minimumSystemVersion": "11.0"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icons/icon.png"
    },
    "extraResources": [
      {
        "from": "dist/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "python-backend.js",
      "frontend/**/*"
    ]
  }
}
